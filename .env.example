# FACEIT Data API key (free, from https://developers.faceit.com / FACEIT App Studio).
# Required ONLY for `faceit-sync fetch`, which enumerates a championship's match
# IDs via the documented Data API. The match/democracy/stats detail endpoints are
# public and need no key.
FACEIT_API_KEY=

# Path to the SQLite database file.
FACEIT_DB=faceit.sqlite3

# owscout (sibling tool) writes its own DB; it opens FACEIT_DB read-only.
OWSCOUT_DB=owscout.sqlite3
OWSCOUT_LOG_LEVEL=INFO

# Politeness: global request rate cap (requests/second) and log level.
FACEIT_RATE_LIMIT=4
FACEIT_LOG_LEVEL=INFO
